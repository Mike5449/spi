# ----------------------------------------------------------------
# SPI — Variables d'environnement (copier en .env et remplir)
# ----------------------------------------------------------------
# Ne JAMAIS commit le fichier .env (présent dans .gitignore).

# ---- Port d'écoute du conteneur web ----
# 80   = port standard HTTP (recommandé sur un VPS dédié)
# 8080 = derrière un nginx hôte qui termine TLS et forward vers 127.0.0.1:8080
WEB_PORT=80

# ---- Postgres ----
POSTGRES_USER=spi
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=spi
# Port hôte (loopback seulement) pour psql/pg_dump depuis le VPS
DB_PORT=5433

# ---- JWT (dashboard SPI) ----
# Génère avec : python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_run_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Chiffrement Fernet (credentials MonCash des utilisateurs) ----
# Génère avec : python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# ⚠️ Si tu changes cette clé, tous les credentials MonCash chiffrés deviennent illisibles.
FERNET_KEY=CHANGE_ME_run_fernet_generate_key

# ---- MonCash plateforme (sandbox transmis manuellement par WhatsApp) ----
# Ces valeurs servent quand TU envoies des credentials sandbox aux utilisateurs.
# Laisser vides si tu n'utilises pas le sandbox de la plateforme.
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_ENVIRONMENT=sandbox

# ---- CORS ----
# Liste des origines autorisées séparées par des virgules.
# Mets l'URL publique du frontend (avec https en prod).
# Ex: https://spi.tondomaine.com,https://www.spi.tondomaine.com
CORS_ORIGINS=http://localhost,http://127.0.0.1

# ---- Frontend (build args) ----
# URL que le navigateur appelle pour atteindre l'API. En prod : "/api"
# (same-origin, traversé par notre nginx). En dev local sans proxy : "http://localhost:8000".
VITE_API_URL=/api
